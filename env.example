# คัดลอกเป็นตัวแปรใน Coolify (หรือสร้าง .env / .env.prod บนเครื่อง)
# ค่าที่จำเป็นขั้นต่ำให้แอป boot ได้ — รายละเอียดครบอยู่ที่ src/core/env/config.ts

NODE_ENV=production
PORT=3000
HOST=0.0.0.0

DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE

JWT_ACCESS_SECRET=เปลี่ยนเป็นสตริงยาวอย่างน้อย-32-ตัวอักษร
JWT_REFRESH_SECRET=เปลี่ยนเป็นสตริงยาวอย่างน้อย-32-ตัวอักษรอีกชุด

# ต้องเป็น origin ของ API จริง (ไม่มี path ท้าย)
BETTER_AUTH_URL=https://api.example.com

SMTP_FROM=noreply@example.com
