# คัดลอกเป็น .env / .env.dev / .env.prod หรือตั้งใน Coolify
# รายละเอียดค่าเริ่มต้นและตัวเลือกเสริม: src/core/env/config.ts
#
# Legacy SQL: ไม่ใส่ใน env — ใส่ไฟล์ .sql ในโฟลเดอร์ LEGACY_SQL_DIR (ค่าเริ่มต้น config/legacy-sql)

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE

JWT_ACCESS_SECRET=สตริงยาวอย่างน้อย-32-ตัวอักษร
JWT_REFRESH_SECRET=สตริงยาวอย่างน้อย-32-ตัวอักษรอีกชุด

# production บังคับ
# BETTER_AUTH_URL=https://api.example.com

SMTP_FROM=noreply@example.com
